{
  "alias": {
    "color": {
      "primary": {
        "interaction": {
          "$value": "{mode.primary.interaction}",
          "$type": "color",
          "$description": "color that indicates interactions"
        },
        "onInteraction": {
          "$value": "{mode.primary.onInteraction}",
          "$type": "color",
          "$description": "color for elements that are placed on interactive background colors"
        },
        "brand": {
          "$value": "{mode.primary.brand}",
          "$type": "color",
          "$description": "background color for primary brand elements"
        },
        "onBrand": {
          "$value": "{mode.primary.onBrand}",
          "$type": "color",
          "$description": "color for elements that are placed on brand background color"
        }
      },
      "secondary": {
        "interaction": {
          "$value": "{mode.secondary.interaction}",
          "$type": "color",
          "$description": "secondary interaction color for backgrounds"
        },
        "onInteraction": {
          "$value": "{mode.secondary.onInteraction}",
          "$type": "color",
          "$description": "secondary foreground color for interactions"
        },
        "brand": {
          "$value": "{mode.secondary.brand}",
          "$type": "color",
          "$description": "secondary brand color for backgrounds"
        },
        "onBrand": {
          "$value": "{mode.secondary.onBrand}",
          "$type": "color",
          "$description": "secondary brand color for backgrounds"
        }
      },
      "intent": {
